# Supabase — vars requeridas por la app.
# Copialo a .env.local y completá con valores reales del dashboard de Supabase.

# ────────────────────────────────────────────────────────────────────────────
# Postgres
# ────────────────────────────────────────────────────────────────────────────
# Direct connection (port 5432) — para drizzle-kit + dev local
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Transaction pooler (port 6543) — para producción / serverless
DATABASE_URL_POOLED=postgresql://postgres:[YOUR-DB-PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres

# ────────────────────────────────────────────────────────────────────────────
# Supabase JS client (Auth + Storage + Realtime)
# ────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Server-only — bypassa RLS. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
