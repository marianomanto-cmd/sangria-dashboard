    "db:backfill-reports": "node --env-file=.env.local scripts/backfill-reports.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "d3-geo": "^3.1.1",
